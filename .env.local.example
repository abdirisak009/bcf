# Development only — copy to .env.local (never commit .env.local).
# For production VPS use .env.production (see .env.production.example).
#
NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# Same value as backend DASHBOARD_WRITE_KEY — used only on the server to authorize
# “New article” from the dashboard. Min 8 characters; keep secret in production.
DASHBOARD_WRITE_KEY=change-me-long-random-string

# Cloudinary — dashboard uploads (Next.js route and Go POST /api/upload).
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
