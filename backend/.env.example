# Isku dheji docker run / docker-compose (postgres-bcf, port 5433).

DB_HOST=localhost
DB_PORT=5433
DB_USER=bcf
DB_PASSWORD=your_password_here
DB_NAME=BcfDb

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_MINUTES=1440
HTTP_PORT=8080
GIN_MODE=debug
APP_ENV=development

# Comma-separated browser origins for CORS (production: your site URL(s), e.g. http://YOUR_VPS_IP, https://yourdomain.com).
# CORS_ALLOW_ORIGINS=http://62.72.35.109,https://bcf.so

# --- Public website origin (no trailing slash) ---
# PUBLIC_SITE_URL: live Next.js site (https). Used for default logo URL, certificate data, and QR when not localhost.
PUBLIC_SITE_URL=https://domainkaaga.so
#
# Optional fallback if PUBLIC_SITE_URL is empty:
# PUBLIC_WEB_URL=https://domainkaaga.so
#
# CERTIFICATE_QR_SITE_URL: optional HTTPS origin used only for PDF QR codes and /verify links on the certificate.
# If unset, PUBLIC_SITE_URL (then PUBLIC_WEB_URL) is used. If those are http://127.0.0.1, the QR will not open
# on a phone — set this to your real https://domain so scans go to https://domain/verify?no=BCF-...
# CERTIFICATE_QR_SITE_URL=https://domainkaaga.so

# Optional: must match Next.js DASHBOARD_WRITE_KEY so dashboard can POST /api/news without JWT.
# Also works for POST /api/upload without a Bearer token (curl / server scripts):
#   curl -sS -X POST http://127.0.0.1:8080/api/upload -H "X-Dashboard-Key: YOUR_KEY" -F "file=@test.jpg" -F "folder=news"
DASHBOARD_WRITE_KEY=change-me-long-random-string

# --- MinIO (required for POST /api/upload — same values as Next.js .env) ---
# MINIO_ENDPOINT=your-minio-host
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=bararug-uploads
# MINIO_USE_SSL=false
# MINIO_REGION=

# --- Dev only: optional upload without JWT (never set in production; use APP_ENV=production) ---
# DEV_UPLOAD_BYPASS_KEY=local-dev-secret
# curl: -H "X-Dev-Upload-Bypass: local-dev-secret" (with APP_ENV=development)

# Login returns JWT for Bearer uploads:
#   curl -sS -X POST http://127.0.0.1:8080/api/auth/login -H "Content-Type: application/json" \
#     -d '{"email":"you@example.com","password":"your-password"}' | jq -r '.data.token'
# Then:
#   curl -sS -X POST http://127.0.0.1:8080/api/upload -H "Authorization: Bearer TOKEN" -F "file=@test.jpg" -F "folder=news"

# Optional: training certificate PDF — full URL to PNG/JPEG background (e.g. file in Next.js public/).
# PDF (recommended): import Acrobat template + overlay text — put certificate-template.pdf in Next.js public/
# CERTIFICATE_TEMPLATE_URL=http://localhost:3000/certificate-template.pdf
# Or PNG/JPEG full-page background + full text overlay:
# CERTIFICATE_TEMPLATE_URL=http://localhost:3000/certificate-template.png
# CERTIFICATE_SIGNATORY_NAME=Your Name
# CERTIFICATE_SIGNATORY_TITLE=Managing Director, Bararug Consulting

# --- WhatsApp sendText API (WAHA-style): thank-you to applicant on apply + optional admin copy; approval message to applicant ---
# Also used for: free training self-registration + Precepts status (applicant phone on the registration).
# Set URL + API key (same as curl X-Api-Key). chatId is built as PHONE_DIGITS@c.us from the application phone.
# WHATSAPP_SENDTEXT_URL=http://178.18.245.131:3002/api/sendText
# WHATSAPP_SENDTEXT_API_KEY=your-api-key-here
# WHATSAPP_SENDTEXT_SESSION=default
# Optional: explicit URL for POST /api/sendFile (PDF certificates to applicant). If omitted, "sendText" in WHATSAPP_SENDTEXT_URL is replaced with "sendFile".
# WHATSAPP_SENDFILE_URL=http://178.18.245.131:3002/api/sendFile
# WHATSAPP_NOTIFY_TO=252613685943
#
# If WHATSAPP_SENDTEXT_* is unset, legacy WHATSAPP_PROVIDER (webhook/callmebot/ultramsg) below is used for admin only.

# --- WhatsApp: notify admin when someone submits a training application (optional) ---
# WHATSAPP_PROVIDER=ultramsg
# WHATSAPP_ULTRAMSG_INSTANCE=your_instance_id
# WHATSAPP_ULTRAMSG_TOKEN=your_instance_token
# WHATSAPP_NOTIFY_TO=252613685943
#
# Or CallMeBot (https://www.callmebot.com/blog/free-api-whatsapp-messages/):
# WHATSAPP_PROVIDER=callmebot
# WHATSAPP_CALLMEBOT_APIKEY=your_key
# WHATSAPP_NOTIFY_TO=252613685943
#
# Or your own HTTP endpoint (JSON POST — relay to WhatsApp from your server):
# WHATSAPP_PROVIDER=webhook
# WHATSAPP_WEBHOOK_URL=https://your-server.com/whatsapp-hook
# WHATSAPP_WEBHOOK_BEARER=optional-secret
# WHATSAPP_NOTIFY_TO=252613685943
#
# Link shown in the message body:
# PUBLIC_DASHBOARD_URL=http://178.18.245.131:3000/dashboard

# --- Issued certificates (BCF-YYYY-NNNN) + Sejda PDF template ---
# Point to your Next.js public PDF (form fields: studentName, trainingName, fromDate, toDate, certificateNo, date).
# CERTIFICATE_TEMPLATE_URL=http://localhost:3000/Certificate-tem.pdf
#
# Approve student & create certificate (requires X-Dashboard-Key or admin JWT):
# curl -sS -X POST http://127.0.0.1:8080/api/approve-student \
#   -H "Content-Type: application/json" -H "X-Dashboard-Key: YOUR_DASHBOARD_WRITE_KEY" \
#   -d '{"application_id":"<uuid>","from_date":"2026-01-15","to_date":"2026-03-20"}'
#
# Public: GET /api/certificate/BCF-2026-0001
# Download: GET /api/certificate/BCF-2026-0001/download

# --- One-time: create first admin (login at Next.js /sign-in) ---
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=your-secure-password-min-8-chars
# go run ./cmd/seed-admin

# --- Optional: auto-create admins on server start (bcrypt) if email not in DB yet (up to 5 pairs) ---
# After deploy, set these on the VPS .env then restart the Go API. Omit or leave empty to skip.
# BOOTSTRAP_ADMIN_1_EMAIL=admin1@yourdomain.com
# BOOTSTRAP_ADMIN_1_PASSWORD=your-secure-password-min-8-chars
# BOOTSTRAP_ADMIN_2_EMAIL=admin2@yourdomain.com
# BOOTSTRAP_ADMIN_2_PASSWORD=your-secure-password-min-8-chars
