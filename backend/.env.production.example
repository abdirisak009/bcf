# Production backend — copy relevant lines into backend/.env on the VPS (do not commit secrets).
# Match the public site origin(s) so CORS allows the browser.

APP_ENV=production
GIN_MODE=release

# Comma-separated — no spaces after commas. Include http://YOUR_VPS_IP and https://yourdomain.com when ready.
# Example: CORS_ALLOW_ORIGINS=http://62.72.35.109,http://62.72.35.109:3000,https://bcf.so
CORS_ALLOW_ORIGINS=http://YOUR_VPS_IP,http://YOUR_VPS_IP:3000

# Same origin as the live Next.js website (HTTPS, no trailing slash).
PUBLIC_SITE_URL=https://domainkaaga.so

# Optional: same as PUBLIC_SITE_URL unless you need a different URL only for certificate QR → /verify?no=...
# CERTIFICATE_QR_SITE_URL=https://domainkaaga.so

# Certificate template must be a URL the Go server can fetch (prefer https://yourdomain.com/... not localhost).
# CERTIFICATE_TEMPLATE_URL=https://yourdomain.com/Certificate-tem.pdf

# Cloudinary — match Next.js production env for uploads.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
